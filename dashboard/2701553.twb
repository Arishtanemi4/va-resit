    <worksheet name='KPI_Overall_Sex_Gap'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true'>Gender gap</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='adult_tableau' name='federated.1m7m6p70r2kpjm15se5xs1h5kewp' />
          </datasources>
          <datasource-dependencies datasource='federated.1m7m6p70r2kpjm15se5xs1h5kewp'>
            <column caption='Rate by Sex' datatype='real' name='[Calculation_2879646245351438]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [sex] : SUM(IF [income] = &quot;&gt;50K&quot; THEN 1 ELSE 0 END) } / { FIXED [sex] : COUNT([income]) } * 100' />
            </column>
            <column caption='Overall Sex Gap' datatype='real' name='[Calculation_2879646245425167]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX(IF [sex] = &quot;Male&quot; THEN [Calculation_2879646245351438] END) } - { FIXED : MAX(IF [sex] = &quot;Female&quot; THEN [Calculation_2879646245351438] END) }' />
            </column>
            <column caption='Overall Sex Gap KPI' datatype='string' name='[Calculation_2879646245720080]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='STR(ROUND([Calculation_2879646245425167],1)) + &quot; pt&quot;' />
            </column>
            <column caption='Income' datatype='string' name='[income]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_2879646245720080]' derivation='None' name='[none:Calculation_2879646245720080:nk]' pivot='key' type='nominal' />
            <column caption='Sex' datatype='string' name='[sex]' role='dimension' type='nominal' />
