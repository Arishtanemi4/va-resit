  <worksheets>
    <worksheet name='Gap_by_Occupation_Sex'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true'>Difference in Earning Rate of &gt;50K for both Sexes</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#bbbebf' fontname='-apple-system,BlinkMacSystemFont,Segoe WPC,Segoe UI,system-ui,Ubuntu,Droid Sans,sans-serif' fontsize='13' italic='true'>Same occupation, different outcome with the gap being represented by the line length.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='adult_tableau' name='federated.1m7m6p70r2kpjm15se5xs1h5kewp' />
          </datasources>
          <datasource-dependencies datasource='federated.1m7m6p70r2kpjm15se5xs1h5kewp'>
            <column caption='Rate by Occupation &amp; Sex' datatype='real' name='[Calculation_2879646231388167]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [occupation], [sex] : SUM(IF [income] = &quot;&gt;50K&quot; THEN 1 ELSE 0 END) }&#13;&#10;/ { FIXED [occupation], [sex] : COUNT([income]) } * 100' />
            </column>
            <column caption='Sex Gap (Occupation)' datatype='real' name='[Calculation_2879646231490568]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [occupation] : MAX(IF [sex] = &quot;Male&quot; THEN [Calculation_2879646231388167] END) }&#13;&#10;- { FIXED [occupation] : MAX(IF [sex] = &quot;Female&quot; THEN [Calculation_2879646231388167] END) }' />
            </column>
            <column caption='ABS Sex Gap (Occupation)' datatype='real' name='[Calculation_2879646237356041]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ABS([Calculation_2879646231490568])' />
            </column>
            <column caption='Income' datatype='string' name='[income]' role='dimension' type='nominal' />
            <column-instance column='[occupation]' derivation='None' name='[none:occupation:nk]' pivot='key' type='nominal' />
            <column-instance column='[sex]' derivation='None' name='[none:sex:nk]' pivot='key' type='nominal' />
            <column caption='Occupation' datatype='string' name='[occupation]' role='dimension' type='nominal' />
            <column caption='Sex' datatype='string' name='[sex]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_2879646231388167]' derivation='Sum' name='[sum:Calculation_2879646231388167:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2879646237356041]' derivation='Sum' name='[sum:Calculation_2879646237356041:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <shelf-sorts>
            <shelf-sort-v2 dimension-to-sort='[federated.1m7m6p70r2kpjm15se5xs1h5kewp].[none:occupation:nk]' direction='DESC' is-on-innermost-dimension='true' measure-to-sort-by='[federated.1m7m6p70r2kpjm15se5xs1h5kewp].[sum:Calculation_2879646237356041:qk]' shelf='rows' />
          </shelf-sorts>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='axis'>
            <encoding attr='space' class='1' field='[federated.1m7m6p70r2kpjm15se5xs1h5kewp].[sum:Calculation_2879646231388167:qk]' field-type='quantitative' fold='true' scope='cols' synchronized='true' type='space' />
            <format attr='title' class='1' field='[federated.1m7m6p70r2kpjm15se5xs1h5kewp].[sum:Calculation_2879646231388167:qk]' scope='cols' value='Rate of Earning &gt;50K by Occupation &amp; Sex' />
          </style-rule>
