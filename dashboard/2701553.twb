    <worksheet name='KPI_Largest_Gap'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true'>Largest Gap</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='adult_tableau' name='federated.1m7m6p70r2kpjm15se5xs1h5kewp' />
          </datasources>
          <datasource-dependencies datasource='federated.1m7m6p70r2kpjm15se5xs1h5kewp'>
            <column caption='Rate by Occupation &amp; Sex' datatype='real' name='[Calculation_2879646231388167]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [occupation], [sex] : SUM(IF [income] = &quot;&gt;50K&quot; THEN 1 ELSE 0 END) }&#13;&#10;/ { FIXED [occupation], [sex] : COUNT([income]) } * 100' />
            </column>
            <column caption='Sex Gap (Occupation)' datatype='real' name='[Calculation_2879646231490568]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [occupation] : MAX(IF [sex] = &quot;Male&quot; THEN [Calculation_2879646231388167] END) }&#13;&#10;- { FIXED [occupation] : MAX(IF [sex] = &quot;Female&quot; THEN [Calculation_2879646231388167] END) }' />
            </column>
            <column caption='Max Abs Sex Gap' datatype='real' name='[Calculation_2879646244790283]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX(ABS([Calculation_2879646231490568])) }' />
            </column>
            <column caption='Max Gap Occupation' datatype='string' name='[Calculation_2879646244851724]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='{ FIXED : MAX(IF ABS([Calculation_2879646231490568]) = [Calculation_2879646244790283] THEN [occupation] END) }' />
            </column>
            <column caption='Largest Gap Label' datatype='string' name='[Calculation_2879646244970509]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Calculation_2879646244851724] + &quot;: &quot; + STR(ROUND([Calculation_2879646244790283],1)) + &quot; pt&quot;' />
            </column>
            <column caption='Income' datatype='string' name='[income]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_2879646244970509]' derivation='None' name='[none:Calculation_2879646244970509:nk]' pivot='key' type='nominal' />
            <column caption='Occupation' datatype='string' name='[occupation]' role='dimension' type='nominal' />
            <column caption='Sex' datatype='string' name='[sex]' role='dimension' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='cell'>
            <format attr='height' value='79' />
            <format attr='width' value='196' />
          </style-rule>
          <style-rule element='worksheet'>
            <format attr='font-weight' value='bold' />
