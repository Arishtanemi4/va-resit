      <column caption='Variables Used (Projections)' datatype='string' name='[Calculation_2086070853738496]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;age, workclass, education, marital-status, occupation, relationship, race, sex, capital-gain, capital-loss, hours-per-week, native-country&quot;' />
      </column>
      <column caption='Pct Above 50K' datatype='real' name='[Calculation_2086070853890049]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [income] = &quot;&gt;50K&quot; THEN 1 ELSE 0 END) / COUNT([income])' />
      </column>
      <column caption='Has Capital Gain' datatype='boolean' name='[Calculation_2086070853984258]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[capital-gain] &gt; 0' />
      </column>
      <column caption='Pct With Capital Gain' datatype='real' name='[Calculation_2086070854127619]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT([Calculation_2086070853984258])) / COUNT([capital-gain])' />
      </column>
      <column caption='Workclass Imputed (Count)' datatype='integer' name='[Calculation_2086070856519684]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT([workclass-imputed]))' />
      </column>
      <column caption='Occupation Imputed (Count)' datatype='integer' name='[Calculation_2086070856605701]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT([occupation-imputed]))' />
      </column>
      <column caption='Native Country Imputed (Count)' datatype='integer' name='[Calculation_2086070856704006]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT([native-country-imputed]))' />
      </column>
      <column caption='Total People' datatype='integer' name='[Calculation_2086070856814599]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([income])' />
      </column>
      <column caption='Total Imputed' datatype='integer' name='[Calculation_2086070856892424]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT([workclass-imputed])) + SUM(INT([occupation-imputed])) + SUM(INT([native-country-imputed]))' />
      </column>
      <column caption='Features In Projection' datatype='integer' name='[Calculation_2086070857052169]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='12' />
      </column>
      <column caption='Dominant Share (Country)' datatype='real' name='[Calculation_2086070857109514]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [native-country] = &quot;United-States&quot; THEN 1 ELSE 0 END) / COUNT([native-country])' />
      </column>
      <column caption='Dominant Share (Race)' datatype='real' name='[Calculation_2086070857232395]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [race] = &quot;White&quot; THEN 1 ELSE 0 END) / COUNT([race])' />
      </column>
      <column caption='Dominant Share (Sex)' datatype='real' name='[Calculation_2086070857314316]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [sex] = &quot;Male&quot; THEN 1 ELSE 0 END) / COUNT([sex])' />
      </column>
      <column caption='Education Order' datatype='integer' name='[Calculation_2086070857400333]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [education]&#13;&#10;WHEN &apos;Preschool&apos; THEN 0   WHEN &apos;1st-4th&apos; THEN 1     WHEN &apos;5th-6th&apos; THEN 2&#13;&#10;WHEN &apos;7th-8th&apos; THEN 3     WHEN &apos;9th&apos; THEN 4         WHEN &apos;10th&apos; THEN 5&#13;&#10;WHEN &apos;11th&apos; THEN 6        WHEN &apos;12th&apos; THEN 7        WHEN &apos;HS-grad&apos; THEN 8&#13;&#10;WHEN &apos;Some-college&apos; THEN 9 WHEN &apos;Assoc-voc&apos; THEN 10 WHEN &apos;Assoc-acdm&apos; THEN 11&#13;&#10;WHEN &apos;Bachelors&apos; THEN 12  WHEN &apos;Masters&apos; THEN 13    WHEN &apos;Prof-school&apos; THEN 14&#13;&#10;WHEN &apos;Doctorate&apos; THEN 15&#13;&#10;END' />
      </column>
      <column caption='Income Measure' datatype='real' name='[Calculation_2086070904778766]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Count&quot; THEN&#13;&#10;    COUNT([income])&#13;&#10;ELSE&#13;&#10;    COUNT([income]) / TOTAL(COUNT([income]))&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Show tSNE Income?' datatype='boolean' name='[Calculation_2086070905057295]' role='dimension' type='nominal'>
