          <datasource-dependencies datasource='federated.1m7m6p70r2kpjm15se5xs1h5kewp'>
            <column caption='Cell Count LOD' datatype='integer' name='[Calculation_2879646246113297]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [education],[occupation] : COUNT([income]) }' />
            </column>
            <column caption='Cell Rate LOD' datatype='real' name='[Calculation_2879646246170642]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [education],[occupation] :&#13;&#10;                             SUM(IF [income] = &quot;&gt;50K&quot; THEN 1 ELSE 0 END) } / [Calculation_2879646246113297] * 100' />
            </column>
            <column caption='Cell Rate LOD (guarded)' datatype='real' name='[Calculation_2879646246465555]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_2879646246113297] &gt;= 30 THEN [Calculation_2879646246170642] END' />
            </column>
            <column caption='Max Guarded Cell Rate' datatype='real' name='[Calculation_2879646246531092]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX([Calculation_2879646246465555]) }' />
            </column>
            <column caption='Max Cell Education' datatype='string' name='[Calculation_2879646246596629]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='{ FIXED : MAX(IF [Calculation_2879646246465555] = [Calculation_2879646246531092]&#13;&#10;                                         THEN [education] END) }' />
            </column>
            <column caption='Max Cell Occupation' datatype='string' name='[Calculation_2879646246658070]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='{ FIXED : MAX(IF [Calculation_2879646246465555] = [Calculation_2879646246531092]&#13;&#10;                                         THEN [occupation] END) }' />
            </column>
            <column caption='Top Combination Label' datatype='string' name='[Calculation_2879646246719511]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Calculation_2879646246596629] + &quot; + &quot; + [Calculation_2879646246658070] + &quot;: &quot;&#13;&#10;                           + STR(ROUND([Calculation_2879646246531092],1)) + &quot;% earn &gt;$50K&quot;' />
            </column>
            <column caption='Education' datatype='string' name='[education]' role='dimension' type='nominal' />
            <column caption='Income' datatype='string' name='[income]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_2879646246719511]' derivation='None' name='[none:Calculation_2879646246719511:nk]' pivot='key' type='nominal' />
            <column caption='Occupation' datatype='string' name='[occupation]' role='dimension' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
