    <worksheet name='KPI_Heatmap_Selection'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true'>Selected Category</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='adult_tableau' name='federated.1m7m6p70r2kpjm15se5xs1h5kewp' />
          </datasources>
          <datasource-dependencies datasource='federated.1m7m6p70r2kpjm15se5xs1h5kewp'>
            <column caption='Pct Above 50K' datatype='real' default-format='n#,##0.00&quot;%&quot;;-#,##0.00&quot;%&quot;' name='[Calculation_2086070853890049]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM(IF [income] = &quot;&gt;50K&quot; THEN 1 ELSE 0 END) / COUNT([income]))*100' />
            </column>
            <column caption='Selected Category KPI Text' datatype='string' name='[Calculation_2305150642188288]' role='measure' type='nominal'>
              <calculation class='tableau' formula='STR(COUNT([income])) + &quot; people · &quot; + STR(ROUND([Calculation_2086070853890049], 1)) + &quot;% earn &gt;$50K&quot;' />
            </column>
            <column caption='Education' datatype='string' name='[education]' role='dimension' type='nominal' />
            <column caption='Income' datatype='string' name='[income]' role='dimension' type='nominal' />
            <column caption='Occupation' datatype='string' name='[occupation]' role='dimension' type='nominal' />
            <column caption='Sex' datatype='string' name='[sex]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_2305150642188288]' derivation='User' name='[usr:Calculation_2305150642188288:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1m7m6p70r2kpjm15se5xs1h5kewp].[Action (Education,Occupation)]'>
            <groupfilter function='crossjoin' user:ui-action-filter='[Action5_E07B8393A0D44A4691295B977C526B40]' user:ui-enumeration='all' user:ui-marker='enumerate'>
              <groupfilter function='level-members' level='[education]' />
              <groupfilter function='level-members' level='[occupation]' />
            </groupfilter>
          </filter>
          <filter class='categorical' column='[federated.1m7m6p70r2kpjm15se5xs1h5kewp].[Action (Occupation)]'>
            <groupfilter function='level-members' level='[occupation]' user:ui-action-filter='[Action5_E07B8393A0D44A4691295B977C526B40]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
