    <worksheet name='Rate_Heatmap'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true'>Occupation &amp; Education Rate of &gt;50K income</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#bbbebf' fontname='-apple-system,BlinkMacSystemFont,Segoe WPC,Segoe UI,system-ui,Ubuntu,Droid Sans,sans-serif' fontsize='13' italic='true'>Some Education × Occupation combinations rest on very few people — read extreme cells cautiously.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='adult_tableau' name='federated.1m7m6p70r2kpjm15se5xs1h5kewp' />
          </datasources>
          <datasource-dependencies datasource='federated.1m7m6p70r2kpjm15se5xs1h5kewp'>
            <column caption='Pct Above 50K' datatype='real' default-format='n#,##0.00&quot;%&quot;;-#,##0.00&quot;%&quot;' name='[Calculation_2086070853890049]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM(IF [income] = &quot;&gt;50K&quot; THEN 1 ELSE 0 END) / COUNT([income]))*100' />
            </column>
            <column caption='Total People' datatype='integer' name='[Calculation_2086070856814599]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([income])' />
            </column>
            <column caption='Education Order' datatype='integer' name='[Calculation_2086070857400333]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [education]&#13;&#10;WHEN &apos;Preschool&apos; THEN 0   WHEN &apos;1st-4th&apos; THEN 1     WHEN &apos;5th-6th&apos; THEN 2&#13;&#10;WHEN &apos;7th-8th&apos; THEN 3     WHEN &apos;9th&apos; THEN 4         WHEN &apos;10th&apos; THEN 5&#13;&#10;WHEN &apos;11th&apos; THEN 6        WHEN &apos;12th&apos; THEN 7        WHEN &apos;HS-grad&apos; THEN 8&#13;&#10;WHEN &apos;Some-college&apos; THEN 9 WHEN &apos;Assoc-voc&apos; THEN 10 WHEN &apos;Assoc-acdm&apos; THEN 11&#13;&#10;WHEN &apos;Bachelors&apos; THEN 12  WHEN &apos;Masters&apos; THEN 13    WHEN &apos;Prof-school&apos; THEN 14&#13;&#10;WHEN &apos;Doctorate&apos; THEN 15&#13;&#10;END' />
            </column>
            <column caption='Count Above 50K' datatype='integer' name='[Calculation_2305150656696321]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [income] = &quot;&gt;50K&quot; THEN 1 ELSE 0 END)' />
            </column>
            <column caption='Education' datatype='string' name='[education]' role='dimension' type='nominal' />
            <column caption='Income' datatype='string' name='[income]' role='dimension' type='nominal' />
            <column-instance column='[education]' derivation='None' name='[none:education:nk]' pivot='key' type='nominal' />
            <column-instance column='[occupation]' derivation='None' name='[none:occupation:nk]' pivot='key' type='nominal' />
            <column caption='Occupation' datatype='string' name='[occupation]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_2086070857400333]' derivation='Sum' name='[sum:Calculation_2086070857400333:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2086070853890049]' derivation='User' name='[usr:Calculation_2086070853890049:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2086070856814599]' derivation='User' name='[usr:Calculation_2086070856814599:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2305150656696321]' derivation='User' name='[usr:Calculation_2305150656696321:qk]' pivot='key' type='quantitative' />
