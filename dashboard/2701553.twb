      </column>
      <column caption='Max Abs Sex Gap' datatype='real' name='[Calculation_2879646244790283]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(ABS([Calculation_2879646231490568])) }' />
      </column>
      <column caption='Max Gap Occupation' datatype='string' name='[Calculation_2879646244851724]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF ABS([Calculation_2879646231490568]) = [Calculation_2879646244790283] THEN [occupation] END) }' />
      </column>
      <column caption='Largest Gap Label' datatype='string' name='[Calculation_2879646244970509]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_2879646244851724] + &quot;: &quot; + STR(ROUND([Calculation_2879646244790283],1)) + &quot; pt&quot;' />
      </column>
      <column caption='Rate by Sex' datatype='real' name='[Calculation_2879646245351438]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [sex] : SUM(IF [income] = &quot;&gt;50K&quot; THEN 1 ELSE 0 END) } / { FIXED [sex] : COUNT([income]) } * 100' />
      </column>
      <column caption='Overall Sex Gap' datatype='real' name='[Calculation_2879646245425167]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF [sex] = &quot;Male&quot; THEN [Calculation_2879646245351438] END) } - { FIXED : MAX(IF [sex] = &quot;Female&quot; THEN [Calculation_2879646245351438] END) }' />
