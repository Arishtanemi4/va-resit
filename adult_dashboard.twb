    <worksheet name='Income_by_Education'>
      <table>
        <view>
          <datasources>
            <datasource caption='Adult Imputed' name='federated.imp' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Show As' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Absolute&quot;'>
              <calculation class='tableau' formula='&quot;Absolute&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.imp'>
            <column caption='Education' datatype='string' name='[education]' role='dimension' type='nominal' />
            <column caption='Education Num' datatype='integer' name='[education_num]' role='measure' type='quantitative' />
            <column caption='Income' datatype='string' name='[income]' role='dimension' type='nominal' />
            <column caption='Count' datatype='integer' name='[Count]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='1' />
            </column>
            <column caption='Value by Education' datatype='real' name='[Calculation_ValByEdu]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Absolute&quot; THEN SUM([Count]) ELSE SUM([Count]) / AVG({FIXED [education] : SUM([Count])}) END' />
            </column>
            <column-instance column='[education]' derivation='None' name='[none:education:nk]' pivot='key' type='nominal' />
            <column-instance column='[income]' derivation='None' name='[none:income:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_ValByEdu]' derivation='User' name='[usr:Calculation_ValByEdu:qk]' pivot='key' type='quantitative' />
            <column-instance column='[education_num]' derivation='Min' name='[min:education_num:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <sort class='computed' column='[federated.imp].[none:education:nk]' direction='ASC' using='[federated.imp].[min:education_num:qk]' />
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='mark'>
            <encoding attr='color' field='[federated.imp].[none:income:nk]' type='palette'>
              <map to='#2a78d6'><bucket>&quot;&lt;=50K&quot;</bucket></map>
              <map to='#eb6834'><bucket>&quot;&gt;50K&quot;</bucket></map>
            </encoding>
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <encodings>
              <color column='[federated.imp].[none:income:nk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.imp].[usr:Calculation_ValByEdu:qk]</rows>
        <cols>[federated.imp].[none:education:nk]</cols>
      </table>
    </worksheet>
    <worksheet name='Income_by_Occupation'>
      <table>
        <view>
          <datasources>
            <datasource caption='Adult Imputed' name='federated.imp' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Show As' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Absolute&quot;'>
              <calculation class='tableau' formula='&quot;Absolute&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.imp'>
            <column caption='Occupation' datatype='string' name='[occupation]' role='dimension' type='nominal' />
            <column caption='Income' datatype='string' name='[income]' role='dimension' type='nominal' />
            <column caption='Count' datatype='integer' name='[Count]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='1' />
            </column>
            <column caption='Value by Occupation' datatype='real' name='[Calculation_ValByOcc]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Absolute&quot; THEN SUM([Count]) ELSE SUM([Count]) / AVG({FIXED [occupation] : SUM([Count])}) END' />
            </column>
            <column-instance column='[occupation]' derivation='None' name='[none:occupation:nk]' pivot='key' type='nominal' />
            <column-instance column='[income]' derivation='None' name='[none:income:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_ValByOcc]' derivation='User' name='[usr:Calculation_ValByOcc:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Count]' derivation='Sum' name='[sum:Count:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <sort class='computed' column='[federated.imp].[none:occupation:nk]' direction='DESC' using='[federated.imp].[sum:Count:qk]' />
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='mark'>
            <encoding attr='color' field='[federated.imp].[none:income:nk]' type='palette'>
              <map to='#2a78d6'><bucket>&quot;&lt;=50K&quot;</bucket></map>
              <map to='#eb6834'><bucket>&quot;&gt;50K&quot;</bucket></map>
            </encoding>
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <encodings>
              <color column='[federated.imp].[none:income:nk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.imp].[none:occupation:nk]</rows>
        <cols>[federated.imp].[usr:Calculation_ValByOcc:qk]</cols>
      </table>
    </worksheet>
    <worksheet name='Income_by_Age'>
      <table>
        <view>
          <datasources>
            <datasource caption='Adult Imputed' name='federated.imp' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Show As' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Absolute&quot;'>
              <calculation class='tableau' formula='&quot;Absolute&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.imp'>
            <column caption='Age' datatype='integer' name='[age]' role='measure' type='quantitative' />
            <column caption='Age Band' datatype='integer' name='[Age Band]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='INT([age]/5)*5' />
            </column>
            <column caption='Income' datatype='string' name='[income]' role='dimension' type='nominal' />
            <column caption='Count' datatype='integer' name='[Count]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='1' />
            </column>
            <column caption='Value by Age Band' datatype='real' name='[Calculation_ValByAge]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Absolute&quot; THEN SUM([Count]) ELSE SUM([Count]) / AVG({FIXED [Age Band] : SUM([Count])}) END' />
            </column>
            <column-instance column='[Age Band]' derivation='None' name='[none:Age Band:ok]' pivot='key' type='ordinal' />
            <column-instance column='[income]' derivation='None' name='[none:income:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_ValByAge]' derivation='User' name='[usr:Calculation_ValByAge:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='mark'>
            <encoding attr='color' field='[federated.imp].[none:income:nk]' type='palette'>
              <map to='#2a78d6'><bucket>&quot;&lt;=50K&quot;</bucket></map>
              <map to='#eb6834'><bucket>&quot;&gt;50K&quot;</bucket></map>
            </encoding>
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <encodings>
              <color column='[federated.imp].[none:income:nk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.imp].[usr:Calculation_ValByAge:qk]</rows>
        <cols>[federated.imp].[none:Age Band:ok]</cols>
      </table>
    </worksheet>
    <worksheet name='Bayesian_Imputation_QA'>
      <table>
        <view>
          <datasources>
            <datasource caption='Adult Imputed' name='federated.imp' />
          </datasources>
          <datasource-dependencies datasource='federated.imp'>
            <column caption='Workclass' datatype='string' name='[workclass]' role='dimension' type='nominal' />
            <column caption='Workclass Was Imputed' datatype='string' name='[workclass_was_imputed]' role='dimension' type='nominal' />
            <column caption='Count' datatype='integer' name='[Count]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='1' />
            </column>
            <column caption='Pct within Imputed Flag (Workclass)' datatype='real' name='[Calculation_PctWC]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Count]) / AVG({FIXED [workclass_was_imputed] : SUM([Count])})' />
            </column>
            <column-instance column='[workclass]' derivation='None' name='[none:workclass:nk]' pivot='key' type='nominal' />
            <column-instance column='[workclass_was_imputed]' derivation='None' name='[none:workclass_was_imputed:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_PctWC]' derivation='User' name='[usr:Calculation_PctWC:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Count]' derivation='Sum' name='[sum:Count:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <sort class='computed' column='[federated.imp].[none:workclass:nk]' direction='DESC' using='[federated.imp].[sum:Count:qk]' />
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='mark'>
            <encoding attr='color' field='[federated.imp].[none:workclass_was_imputed:nk]' type='palette'>
              <map to='#898781'><bucket>&quot;False&quot;</bucket></map>
              <map to='#2a78d6'><bucket>&quot;True&quot;</bucket></map>
            </encoding>
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <encodings>
              <color column='[federated.imp].[none:workclass_was_imputed:nk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.imp].[none:workclass:nk]</rows>
        <cols>([federated.imp].[none:workclass_was_imputed:nk] * [federated.imp].[usr:Calculation_PctWC:qk])</cols>
      </table>
    </worksheet>
  </worksheets>
