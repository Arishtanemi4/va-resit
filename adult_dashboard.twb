            <column datatype='string' name='occupation' ordinal='6' />
            <column datatype='integer' name='hours_per_week' ordinal='7' />
            <column datatype='string' name='sex' ordinal='8' />
            <column datatype='string' name='variables_used' ordinal='9' />
          </columns>
        </relation>
      </connection>
