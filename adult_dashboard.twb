    <datasource caption='Adult Imputed' inline='true' name='federated.imp' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='adult_imputed' name='textscan.imp'>
            <connection class='textscan' directory='Data' filename='adult_imputed.csv' password='' server='' />
          </named-connection>
        </named-connections>
        <relation connection='textscan.imp' name='adult_imputed.csv' table='[adult_imputed#csv]' type='table'>
          <columns character-set='UTF-8' header='yes' locale='en_GB' separator=','>
            <column datatype='integer' name='index' ordinal='0' />
            <column datatype='integer' name='age' ordinal='1' />
            <column datatype='string' name='workclass' ordinal='2' />
            <column datatype='integer' name='fnlwgt' ordinal='3' />
            <column datatype='string' name='education' ordinal='4' />
            <column datatype='integer' name='education_num' ordinal='5' />
            <column datatype='string' name='marital_status' ordinal='6' />
            <column datatype='string' name='occupation' ordinal='7' />
            <column datatype='string' name='relationship' ordinal='8' />
            <column datatype='string' name='race' ordinal='9' />
            <column datatype='string' name='sex' ordinal='10' />
            <column datatype='integer' name='capital_gain' ordinal='11' />
            <column datatype='integer' name='capital_loss' ordinal='12' />
            <column datatype='integer' name='hours_per_week' ordinal='13' />
            <column datatype='string' name='native_country' ordinal='14' />
            <column datatype='string' name='income' ordinal='15' />
            <column datatype='string' name='native_country_was_unknown' ordinal='16' />
            <column datatype='string' name='workclass_was_imputed' ordinal='17' />
            <column datatype='string' name='occupation_was_imputed' ordinal='18' />
            <column datatype='real' name='workclass_imputed_prob' ordinal='19' />
            <column datatype='real' name='workclass_entropy' ordinal='20' />
            <column datatype='real' name='occupation_imputed_prob' ordinal='21' />
            <column datatype='real' name='occupation_entropy' ordinal='22' />
            <column datatype='string' name='workclass_mode_baseline' ordinal='23' />
            <column datatype='string' name='occupation_mode_baseline' ordinal='24' />
          </columns>
        </relation>
      </connection>
      <column caption='Index' datatype='integer' name='[index]' role='dimension' type='ordinal' />
      <column caption='Age' datatype='integer' name='[age]' role='measure' type='quantitative' />
      <column caption='Workclass' datatype='string' name='[workclass]' role='dimension' type='nominal' />
      <column caption='Education' datatype='string' name='[education]' role='dimension' type='nominal' />
      <column caption='Education Num' datatype='integer' name='[education_num]' role='measure' type='quantitative' />
      <column caption='Marital Status' datatype='string' name='[marital_status]' role='dimension' type='nominal' />
      <column caption='Occupation' datatype='string' name='[occupation]' role='dimension' type='nominal' />
      <column caption='Sex' datatype='string' name='[sex]' role='dimension' type='nominal' />
      <column caption='Hours per Week' datatype='integer' name='[hours_per_week]' role='measure' type='quantitative' />
      <column caption='Income' datatype='string' name='[income]' role='dimension' type='nominal' />
      <column caption='Workclass Was Imputed' datatype='string' name='[workclass_was_imputed]' role='dimension' type='nominal' />
      <column caption='Occupation Was Imputed' datatype='string' name='[occupation_was_imputed]' role='dimension' type='nominal' />
      <column caption='Workclass Imputed Prob' datatype='real' name='[workclass_imputed_prob]' role='measure' type='quantitative' />
      <column caption='Workclass Entropy' datatype='real' name='[workclass_entropy]' role='measure' type='quantitative' />
      <column caption='Occupation Imputed Prob' datatype='real' name='[occupation_imputed_prob]' role='measure' type='quantitative' />
      <column caption='Occupation Entropy' datatype='real' name='[occupation_entropy]' role='measure' type='quantitative' />
      <column caption='Count' datatype='integer' name='[Count]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Age Band' datatype='integer' name='[Age Band]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='INT([age]/5)*5' />
      </column>
      <column caption='Value by Education' datatype='real' name='[Calculation_ValByEdu]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Absolute&quot; THEN SUM([Count]) ELSE SUM([Count]) / AVG({FIXED [education] : SUM([Count])}) END' />
      </column>
      <column caption='Value by Occupation' datatype='real' name='[Calculation_ValByOcc]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Absolute&quot; THEN SUM([Count]) ELSE SUM([Count]) / AVG({FIXED [occupation] : SUM([Count])}) END' />
      </column>
      <column caption='Value by Age Band' datatype='real' name='[Calculation_ValByAge]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Absolute&quot; THEN SUM([Count]) ELSE SUM([Count]) / AVG({FIXED [Age Band] : SUM([Count])}) END' />
      </column>
      <column caption='Pct within Imputed Flag (Workclass)' datatype='real' name='[Calculation_PctWC]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Count]) / AVG({FIXED [workclass_was_imputed] : SUM([Count])})' />
      </column>
      <column caption='Pct within Imputed Flag (Occupation)' datatype='real' name='[Calculation_PctOcc]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Count]) / AVG({FIXED [occupation_was_imputed] : SUM([Count])})' />
      </column>
    </datasource>
  </datasources>
  <worksheets>
    <worksheet name='Proj_PCA'>
      <table>
        <view>
          <datasources>
            <datasource caption='Adult PCA 2D' name='federated.pca' />
          </datasources>
          <datasource-dependencies datasource='federated.pca'>
            <column caption='Index' datatype='integer' name='[index]' role='dimension' type='ordinal' />
            <column caption='PC1' datatype='real' name='[PC1]' role='measure' type='quantitative' />
            <column caption='PC2' datatype='real' name='[PC2]' role='measure' type='quantitative' />
            <column caption='Income' datatype='string' name='[income]' role='dimension' type='nominal' />
            <column caption='Age' datatype='integer' name='[age]' role='measure' type='quantitative' />
            <column caption='Education' datatype='string' name='[education]' role='dimension' type='nominal' />
            <column caption='Occupation' datatype='string' name='[occupation]' role='dimension' type='nominal' />
            <column caption='Hours per Week' datatype='integer' name='[hours_per_week]' role='measure' type='quantitative' />
            <column caption='Sex' datatype='string' name='[sex]' role='dimension' type='nominal' />
            <column caption='Variables Used' datatype='string' name='[variables_used]' role='dimension' type='nominal' />
            <column-instance column='[index]' derivation='None' name='[none:index:nk]' pivot='key' type='ordinal' />
            <column-instance column='[PC1]' derivation='None' name='[none:PC1:qk]' pivot='key' type='quantitative' />
            <column-instance column='[PC2]' derivation='None' name='[none:PC2:qk]' pivot='key' type='quantitative' />
            <column-instance column='[income]' derivation='None' name='[none:income:nk]' pivot='key' type='nominal' />
            <column-instance column='[age]' derivation='None' name='[none:age:qk]' pivot='key' type='quantitative' />
            <column-instance column='[education]' derivation='None' name='[none:education:nk]' pivot='key' type='nominal' />
            <column-instance column='[occupation]' derivation='None' name='[none:occupation:nk]' pivot='key' type='nominal' />
            <column-instance column='[hours_per_week]' derivation='None' name='[none:hours_per_week:qk]' pivot='key' type='quantitative' />
            <column-instance column='[sex]' derivation='None' name='[none:sex:nk]' pivot='key' type='nominal' />
            <column-instance column='[variables_used]' derivation='None' name='[none:variables_used:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <aggregation value='false' />
        </view>
        <style>
          <style-rule element='mark'>
            <encoding attr='color' field='[federated.pca].[none:income:nk]' type='palette'>
              <map to='#2a78d6'><bucket>&quot;&lt;=50K&quot;</bucket></map>
              <map to='#eb6834'><bucket>&quot;&gt;50K&quot;</bucket></map>
            </encoding>
            <format attr='mark-transparency' value='30' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Circle' />
            <encodings>
              <color column='[federated.pca].[none:income:nk]' />
              <lod column='[federated.pca].[none:index:nk]' />
              <tooltip column='[federated.pca].[none:age:qk]' />
              <tooltip column='[federated.pca].[none:education:nk]' />
              <tooltip column='[federated.pca].[none:occupation:nk]' />
              <tooltip column='[federated.pca].[none:hours_per_week:qk]' />
              <tooltip column='[federated.pca].[none:sex:nk]' />
              <tooltip column='[federated.pca].[none:variables_used:nk]' />
            </encodings>
            <customized-tooltip>
              <formatted-text>
                <run bold='true'>income: </run>
                <run>&lt;[federated.pca].[none:income:nk]&gt;&#10;</run>
                <run bold='true'>age: </run>
                <run>&lt;[federated.pca].[none:age:qk]&gt;&#10;</run>
                <run bold='true'>education: </run>
                <run>&lt;[federated.pca].[none:education:nk]&gt;&#10;</run>
                <run bold='true'>occupation: </run>
                <run>&lt;[federated.pca].[none:occupation:nk]&gt;&#10;</run>
                <run bold='true'>hours/week: </run>
                <run>&lt;[federated.pca].[none:hours_per_week:qk]&gt;&#10;</run>
                <run bold='true'>sex: </run>
                <run>&lt;[federated.pca].[none:sex:nk]&gt;&#10;&#10;</run>
                <run fontcolor='#52514e' fontsize='8'>variables used in projection:&#10;&lt;[federated.pca].[none:variables_used:nk]&gt;</run>
              </formatted-text>
            </customized-tooltip>
          </pane>
        </panes>
        <rows>[federated.pca].[none:PC2:qk]</rows>
        <cols>[federated.pca].[none:PC1:qk]</cols>
      </table>
    </worksheet>
