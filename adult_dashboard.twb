      <connection class='federated'>
        <named-connections>
          <named-connection caption='adult_tsne_2d' name='textscan.tsne'>
            <connection class='textscan' directory='Data' filename='adult_tsne_2d.csv' password='' server='' />
          </named-connection>
        </named-connections>
        <relation connection='textscan.tsne' name='adult_tsne_2d.csv' table='[adult_tsne_2d#csv]' type='table'>
