  <datasources>
    <datasource hasconnection='false' inline='true' name='Parameters' version='18.1'>
      <aliases enabled='yes' />
      <column caption='Show As' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Absolute&quot;'>
        <calculation class='tableau' formula='&quot;Absolute&quot;' />
        <members>
          <member value='&quot;Absolute&quot;' />
          <member value='&quot;Proportion&quot;' />
        </members>
      </column>
    </datasource>
    <datasource caption='Adult PCA 2D' inline='true' name='federated.pca' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='adult_pca_2d' name='textscan.pca'>
            <connection class='textscan' directory='Data' filename='adult_pca_2d.csv' password='' server='' />
          </named-connection>
        </named-connections>
        <relation connection='textscan.pca' name='adult_pca_2d.csv' table='[adult_pca_2d#csv]' type='table'>
          <columns character-set='UTF-8' header='yes' locale='en_GB' separator=','>
